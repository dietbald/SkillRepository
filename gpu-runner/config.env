KEY_NAME=gpu-runner
KEY_PATH=~/.ssh/gpu-runner.pem
SECURITY_GROUP=sg-0fab642a87e17fd04
INSTANCE_TYPE=g4dn.xlarge
SPOT_MAX_PRICE=2.00

# Deep Learning Base OSS Nvidia Driver GPU AMI (Ubuntu 22.04) 20260424 — drivers preinstalled
BASE_AMI=ami-0d8b997327d3e981f
GPU_AMI=ami-046a1efbc52fe3b8f

# AMI with TrevorJS gemma-4-26B-A4B-it-uncensored Q4_K_M pre-loaded into ollama
# (built by `bench/bake-trevor-ami.sh`; consumed by `gpu-task chat`).
# Will be populated by the bake script on success.
CHAT_AMI=ami-0cabc793983a7fc25
CHAT_MODEL=trevor-26b-a4b-q4km
CHAT_INSTANCE_TYPE=g5.xlarge

# S3 bucket for file transfer (created on first run)
